generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id          Int      @id @default(autoincrement())
  source      String
  category    String
  title       String
  link        String   @unique
  publishedAt DateTime?
  summary     String
  createdAt   DateTime @default(now())
}
